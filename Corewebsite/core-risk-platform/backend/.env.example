# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/core_risk?schema=public"

# Auth
JWT_SECRET="replace-with-strong-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# Admin seed user
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="change-on-first-login"
ADMIN_NAME="Platform Administrator"

# Excel import path (optional)
EXCEL_IMPORT_PATH="./data/CORE_v7_Integrated.xlsx"
