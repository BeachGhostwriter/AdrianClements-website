{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "prisma migrate dev --name init",
    "migrate:prod": "prisma migrate deploy",
    "seed": "ts-node src/utils/seed.ts",
    "studio": "prisma studio",
    "import": "ts-node src/scripts/importExcel.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.3.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.0",
    "@prisma/client": "^5.15.0",
    "zod": "^3.23.0",
    "winston": "^3.13.0",
    "xlsx": "^0.18.5",
    "shared-types": "*",
    "core-engine": "*",
    "radar-engine": "*",
    "forge-engine": "*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.0",
    "prisma": "^5.15.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.4"
  }
}
